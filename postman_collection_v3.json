{
  "info": {
    "name": "State Machine API v3",
    "description": "API for managing state machines and executions - v3 with Orchestrator Resume support for handling exceptional conditions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/state-machines/api/v1",
      "type": "string"
    },
    {
      "key": "stateMachineId",
      "value": "",
      "type": "string"
    },
    {
      "key": "executionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "batchId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orchestratorId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Monitoring",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check the health status of the service and its dependencies"
          },
          "response": []
        }
      ]
    },
    {
      "name": "State Machines",
      "item": [
        {
          "name": "Create State Machine",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"my-state-machine\",\n  \"name\": \"My State Machine\",\n  \"description\": \"Description of my state machine\",\n  \"definition\": {\n    \"Comment\": \"A Hello World example\",\n    \"StartAt\": \"HelloWorld\",\n    \"States\": {\n      \"HelloWorld\": {\n        \"Type\": \"Pass\",\n        \"Result\": \"Hello World!\",\n        \"End\": true\n      }\n    }\n  },\n  \"type\": \"STANDARD\",\n  \"version\": \"1.0\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/state-machines",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines"]
            },
            "description": "Create a new state machine definition"
          },
          "response": []
        },
        {
          "name": "Get State Machine",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}"]
            },
            "description": "Retrieve a state machine by ID"
          },
          "response": []
        },
        {
          "name": "List State Machines",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/state-machines?name=",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines"],
              "query": [
                {
                  "key": "name",
                  "value": "",
                  "description": "Filter by state machine name"
                }
              ]
            },
            "description": "Retrieve a list of all state machines with optional filtering"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Executions",
      "item": [
        {
          "name": "Start Execution",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"execution-1\",\n  \"input\": {\n    \"key\": \"value\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}/executions",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}", "executions"]
            },
            "description": "Start a new execution for a state machine"
          },
          "response": []
        },
        {
          "name": "Get Execution",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/executions/{{executionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["executions", "{{executionId}}"]
            },
            "description": "Retrieve details of a specific execution"
          },
          "response": []
        },
        {
          "name": "List Executions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}/executions?status=&limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}", "executions"],
              "query": [
                {
                  "key": "status",
                  "value": "",
                  "description": "Filter by execution status (RUNNING, SUCCEEDED, FAILED, CANCELLED, PAUSED)"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Maximum number of results to return"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Number of results to skip"
                }
              ]
            },
            "description": "List all executions for a state machine with filtering and pagination"
          },
          "response": []
        },
        {
          "name": "Count Executions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}/executions/count?status=",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}", "executions", "count"],
              "query": [
                {
                  "key": "status",
                  "value": "",
                  "description": "Filter by execution status"
                }
              ]
            },
            "description": "Get the count of executions matching the filter criteria"
          },
          "response": []
        },
        {
          "name": "Stop Execution",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/executions/{{executionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["executions", "{{executionId}}"]
            },
            "description": "Stop a running execution"
          },
          "response": []
        },
        {
          "name": "Get Execution History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/executions/{{executionId}}/history",
              "host": ["{{baseUrl}}"],
              "path": ["executions", "{{executionId}}", "history"]
            },
            "description": "Retrieve the state transition history for an execution"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transformers",
      "item": [
        {
          "name": "List Transformers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transformers",
              "host": ["{{baseUrl}}"],
              "path": ["transformers"]
            },
            "description": "List available input transformers"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Batch Operations",
      "item": [
        {
          "name": "Execute Batch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filter\": {\n    \"status\": \"FAILED\",\n    \"startTimeFrom\": 0,\n    \"startTimeTo\": 0,\n    \"namePattern\": \"\",\n    \"limit\": 10,\n    \"offset\": 0,\n    \"states\": []\n  },\n  \"namePrefix\": \"retry-batch\",\n  \"concurrency\": 5,\n  \"mode\": \"distributed\",\n  \"stopOnError\": false,\n  \"executionNameList\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}/executions/batch",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}", "executions", "batch"]
            },
            "description": "Execute a batch of executions with specified parameters"
          },
          "response": []
        },
        {
          "name": "Get Batch Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/batch/{{batchId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["batch", "{{batchId}}", "status"]
            },
            "description": "Get the status of a batch execution"
          },
          "response": []
        },
        {
          "name": "Pause Batch",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/batch/{{batchId}}/pause",
              "host": ["{{baseUrl}}"],
              "path": ["batch", "{{batchId}}", "pause"]
            },
            "description": "Pause a running batch execution"
          },
          "response": []
        },
        {
          "name": "Resume Batch",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/batch/{{batchId}}/resume",
              "host": ["{{baseUrl}}"],
              "path": ["batch", "{{batchId}}", "resume"]
            },
            "description": "Resume a paused batch execution"
          },
          "response": []
        },
        {
          "name": "Cancel Batch",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/batch/{{batchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["batch", "{{batchId}}"]
            },
            "description": "Cancel a batch execution"
          },
          "response": []
        },
        {
          "name": "List All Batches",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/batch",
              "host": ["{{baseUrl}}"],
              "path": ["batch"]
            },
            "description": "List all batch executions"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bulk Operations (v1.2.11)",
      "item": [
        {
          "name": "Execute Bulk",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filter\": {\n    \"status\": \"\",\n    \"startTimeFrom\": 0,\n    \"startTimeTo\": 0,\n    \"namePattern\": \"\",\n    \"limit\": 100,\n    \"offset\": 0,\n    \"states\": []\n  },\n  \"namePrefix\": \"bulk-operation\",\n  \"concurrency\": 10,\n  \"mode\": \"concurrent\",\n  \"stopOnError\": false,\n  \"executionNameList\": [],\n  \"doMicroBatch\": true,\n  \"microBatchSize\": 500,\n  \"orchestratorId\": \"\",\n  \"pauseThreshold\": 0.1,\n  \"resumeStrategy\": \"manual\",\n  \"timeoutSeconds\": 300\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}/executions/bulk",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}", "executions", "bulk"]
            },
            "description": "Execute bulk operations with orchestration support (JSON body)"
          },
          "response": []
        },
        {
          "name": "Execute Bulk (Form Data)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "inputs",
                  "type": "file",
                  "src": "/path/to/inputs.json",
                  "description": "JSON file containing array of inputs"
                },
                {
                  "key": "namePrefix",
                  "value": "bulk-form",
                  "type": "text",
                  "description": "Prefix for execution names"
                },
                {
                  "key": "concurrency",
                  "value": "10",
                  "type": "text",
                  "description": "Number of concurrent executions"
                },
                {
                  "key": "mode",
                  "value": "concurrent",
                  "type": "text",
                  "description": "Execution mode: distributed, concurrent, sequential"
                },
                {
                  "key": "stopOnError",
                  "value": "false",
                  "type": "text",
                  "description": "Stop if an error occurs"
                },
                {
                  "key": "doMicroBatch",
                  "value": "true",
                  "type": "text",
                  "description": "Enable micro-batch processing"
                },
                {
                  "key": "microBatchSize",
                  "value": "500",
                  "type": "text",
                  "description": "Size of each micro-batch"
                },
                {
                  "key": "orchestratorId",
                  "value": "",
                  "type": "text",
                  "description": "Custom orchestrator ID"
                },
                {
                  "key": "pauseThreshold",
                  "value": "0.1",
                  "type": "text",
                  "description": "Failure rate threshold for auto-pause (0.0-1.0)"
                },
                {
                  "key": "resumeStrategy",
                  "value": "manual",
                  "type": "text",
                  "description": "Resume strategy: manual, automatic, timeout"
                },
                {
                  "key": "timeoutSeconds",
                  "value": "300",
                  "type": "text",
                  "description": "Timeout for automatic resume"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}/executions/bulk-form",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}", "executions", "bulk-form"]
            },
            "description": "Execute bulk operations with inputs provided as JSON file via form-data. Useful for large input sets."
          },
          "response": []
        },
        {
          "name": "Get Bulk Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bulk/{{orchestratorId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["bulk", "{{orchestratorId}}", "status"]
            },
            "description": "Get the status of a bulk execution"
          },
          "response": []
        },
        {
          "name": "Pause Bulk",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bulk/{{orchestratorId}}/pause",
              "host": ["{{baseUrl}}"],
              "path": ["bulk", "{{orchestratorId}}", "pause"]
            },
            "description": "Pause a running bulk execution"
          },
          "response": []
        },
        {
          "name": "Resume Bulk",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bulk/{{orchestratorId}}/resume",
              "host": ["{{baseUrl}}"],
              "path": ["bulk", "{{orchestratorId}}", "resume"]
            },
            "description": "Resume a paused bulk execution"
          },
          "response": []
        },
        {
          "name": "Cancel Bulk",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bulk/{{orchestratorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["bulk", "{{orchestratorId}}"]
            },
            "description": "Cancel a bulk execution"
          },
          "response": []
        },
        {
          "name": "List All Bulk Executions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bulk",
              "host": ["{{baseUrl}}"],
              "path": ["bulk"]
            },
            "description": "List all bulk executions"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Queue Operations",
      "item": [
        {
          "name": "Enqueue Execution",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stateMachineId\": \"my-state-machine\",\n  \"executionName\": \"queued-execution-1\",\n  \"input\": {\n    \"key\": \"value\"\n  },\n  \"queue\": \"default\",\n  \"sourceExecutionId\": \"\",\n  \"sourceStateName\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/queue/enqueue",
              "host": ["{{baseUrl}}"],
              "path": ["queue", "enqueue"]
            },
            "description": "Add an execution task to the distributed queue"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Message & Resume Operations",
      "item": [
        {
          "name": "Resume Execution",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output\": {\n    \"result\": \"completed\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/executions/{{executionId}}/resume",
              "host": ["{{baseUrl}}"],
              "path": ["executions", "{{executionId}}", "resume"]
            },
            "description": "Resume a paused execution (e.g., waiting on a Message state)"
          },
          "response": []
        },
        {
          "name": "Resume By Correlation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correlationKey\": \"orderId\",\n  \"correlationValue\": \"12345\",\n  \"output\": {\n    \"status\": \"approved\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}/resume-by-correlation",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}", "resume-by-correlation"]
            },
            "description": "Resume executions waiting on a specific correlation key/value pair"
          },
          "response": []
        },
        {
          "name": "Find Waiting Executions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/state-machines/{{stateMachineId}}/waiting?correlationKey=orderId&correlationValue=12345",
              "host": ["{{baseUrl}}"],
              "path": ["state-machines", "{{stateMachineId}}", "waiting"],
              "query": [
                {
                  "key": "correlationKey",
                  "value": "orderId",
                  "description": "The correlation key to search for"
                },
                {
                  "key": "correlationValue",
                  "value": "12345",
                  "description": "The correlation value to search for"
                }
              ]
            },
            "description": "Find executions waiting on a specific correlation"
          },
          "response": []
        },
        {
          "name": "Resume Orchestrator",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batchId\": \"batch-123\",\n  \"microBatchId\": \"micro-batch-456\",\n  \"orchestratorSmId\": \"orchestrator\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orchestrator/resume",
              "host": ["{{baseUrl}}"],
              "path": ["orchestrator", "resume"]
            },
            "description": "Resume a stuck orchestrator (WaitForMicroBatchCompletion/WaitForBulkMicroBatchCompletion) to handle exceptional conditions. Use this when orchestrator is waiting for micro-batch completion signals that may have been lost or delayed.\n\norchestratorSmId values:\n- 'orchestrator' - for standard batch orchestrator\n- 'bulk-orchestrator' - for bulk orchestrator"
          },
          "response": []
        }
      ]
    },
    {
      "name": "API Documentation",
      "item": [
        {
          "name": "Get OpenAPI Spec",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/openapi.json",
              "host": ["{{baseUrl}}"],
              "path": ["openapi.json"]
            },
            "description": "Get the OpenAPI specification for this API"
          },
          "response": []
        }
      ]
    }
  ]
}
